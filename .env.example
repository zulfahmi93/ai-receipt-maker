# Receipt Toolkit Telegram bot — local environment template.
# Copy to `.env` and fill in. Never commit a populated `.env`.

# BotFather-issued token. Required at startup; the host fails fast with
# `InvalidOperationException` when this is missing or whitespace-only.
TELEGRAM_BOT_TOKEN=

# Optional: override standard ASP.NET / .NET Generic Host environment.
# DOTNET_ENVIRONMENT=Development
